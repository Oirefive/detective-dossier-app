{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Detective Dossier",
  "version": "0.1.0",
  "identifier": "com.openai.detective-dossier",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Detective Dossier",
        "width": 1540,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
